generator client {
  provider      = "prisma-client"
  output        = "./generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum ListingStatus {
  FOR_SALE
  FOR_RENT
  FOR_SALE_AND_RENT
  SOLD
  RENTED
  OFF_MARKET
}

enum PropertyType {
  CONDO
  APARTMENT
  HOUSE
  VILLA
  TOWNHOUSE
  PENTHOUSE
  OFFICE_SPACE
  RETAIL_SPACE
  COMMERCIAL_SPACE
  WAREHOUSE
}

enum FeatureCategory {
  UNIT_FEATURE
  COMMON_FACILITY
}

enum TransitLine {
  BTS_SUKHUMVIT
  BTS_SILOM
  MRT_BLUE
  MRT_PURPLE
  ARL
  BRT
}

model Province {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  districts  District[]
  properties Property[]

  @@map("provinces")
}

model District {
  id           String        @id @default(cuid())
  name         String
  slug         String
  provinceId   String
  province     Province      @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  subDistricts SubDistrict[]
  properties   Property[]

  @@unique([slug, provinceId])
  @@map("districts")
}

model SubDistrict {
  id         String     @id @default(cuid())
  name       String
  slug       String
  districtId String
  district   District   @relation(fields: [districtId], references: [id], onDelete: Cascade)
  properties Property[]

  @@unique([slug, districtId])
  @@map("sub_districts")
}

model Property {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  description   String
  propertyType  PropertyType
  status        ListingStatus
  salePrice     Float?
  rentPrice     Float?
  beds          Int?
  baths         Int?
  areaSqm       Float
  address       String

  provinceId    String
  districtId    String?
  subDistrictId String?
  province      Province      @relation(fields: [provinceId], references: [id])
  district      District?     @relation(fields: [districtId], references: [id])
  subDistrict   SubDistrict?  @relation(fields: [subDistrictId], references: [id])

  mapImageUrl   String?
  isFeatured    Boolean       @default(false)
  isPublished   Boolean       @default(false)

  images          PropertyImage[]
  features        PropertyFeature[]
  transitStations PropertyTransit[]
  enquiries       Enquiry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  order      Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Feature {
  id         String            @id @default(cuid())
  category   FeatureCategory
  label      String
  slug       String            @unique
  properties PropertyFeature[]

  @@map("features")
}

model PropertyFeature {
  propertyId String
  featureId  String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  feature    Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([propertyId, featureId])
  @@map("property_features")
}

model TransitStation {
  id         String            @id @default(cuid())
  name       String
  slug       String            @unique
  line       TransitLine
  properties PropertyTransit[]

  @@map("transit_stations")
}

model PropertyTransit {
  id             String         @id @default(cuid())
  propertyId     String
  stationId      String
  distanceMeters Int
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  station        TransitStation @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([propertyId, stationId])
  @@map("property_transit")
}

model Enquiry {
  id          String    @id @default(cuid())
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  name        String
  email       String
  phone       String?
  message     String
  listingType String?
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("enquiries")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("ADMIN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
