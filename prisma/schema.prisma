generator client {
  provider      = "prisma-client"
  output        = "./generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum AvailabilityStatus {
  AVAILABLE
  SOLD
  RENTED
}

enum FeatureCategory {
  UNIT_FEATURE
  AMENITY
}

enum TransitLine {
  BTS_SUKHUMVIT
  BTS_SILOM
  BTS_GOLD
  MRT_BLUE
  MRT_PURPLE
  MRT_YELLOW
  MRT_PINK
  ARL
  SRT_RED
  BRT
}

enum HomeSectionListingType {
  RENT
  SALE
  BOTH
}

model Province {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  districts  District[]
  properties Property[]
  homeSections HomeSection[]
  homeAreaCards HomeAreaCard[]

  @@map("provinces")
}

model District {
  id           String        @id @default(cuid())
  name         String
  slug         String
  provinceId   String
  province     Province      @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  subDistricts SubDistrict[]
  properties   Property[]
  homeSections HomeSection[]
  homeAreaCards HomeAreaCard[]

  @@unique([slug, provinceId])
  @@map("districts")
}

model SubDistrict {
  id         String     @id @default(cuid())
  name       String
  slug       String
  districtId String
  district   District   @relation(fields: [districtId], references: [id], onDelete: Cascade)
  properties Property[]

  @@unique([slug, districtId])
  @@map("sub_districts")
}

model PropertyType {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  properties Property[]
  homeSections HomeSection[]

  @@map("property_types")
}

model Property {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  description    String
  propertyTypeId String
  propertyType   PropertyType @relation(fields: [propertyTypeId], references: [id])
  isForSale          Boolean            @default(false)
  isForRent          Boolean            @default(false)
  availabilityStatus AvailabilityStatus @default(AVAILABLE)
  salePrice     Float?
  rentPrice     Float?
  beds          Int?
  baths         Int?
  areaSqm       Float
  address       String

  provinceId    String
  districtId    String?
  subDistrictId String?
  province      Province      @relation(fields: [provinceId], references: [id])
  district      District?     @relation(fields: [districtId], references: [id])
  subDistrict   SubDistrict?  @relation(fields: [subDistrictId], references: [id])

  lat           Float?
  lng           Float?

  mapImageUrl   String?
  isFeatured    Boolean       @default(false)
  isPublished   Boolean       @default(false)
  isPetFriendly Boolean       @default(false)

  images          PropertyImage[]
  features        PropertyFeature[]
  transitStations PropertyTransit[]
  enquiries       Enquiry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  order      Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Feature {
  id         String            @id @default(cuid())
  category   FeatureCategory
  label      String
  slug       String            @unique
  icon       String?
  properties PropertyFeature[]

  @@map("features")
}

model PropertyFeature {
  propertyId String
  featureId  String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  feature    Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([propertyId, featureId])
  @@map("property_features")
}

model TransitStation {
  id         String            @id @default(cuid())
  code       String?           @unique
  name       String
  slug       String            @unique
  line       TransitLine
  lat        Float?
  lng        Float?
  properties PropertyTransit[]

  @@map("transit_stations")
}

model PropertyTransit {
  id             String         @id @default(cuid())
  propertyId     String
  stationId      String
  distanceMeters Int
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  station        TransitStation @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([propertyId, stationId])
  @@map("property_transit")
}

model Enquiry {
  id          String    @id @default(cuid())
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  name        String
  email       String
  phone       String?
  message     String
  listingType String?
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("enquiries")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("ADMIN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  mediaImages   MediaImage[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model MediaImage {
  id           String   @id @default(cuid())
  key          String   @unique
  filename     String
  size         Int
  mimeType     String
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@map("media_images")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model HomeSection {
  id             String                 @id @default(cuid())
  title          String
  propertyTypeId String?
  propertyType   PropertyType?          @relation(fields: [propertyTypeId], references: [id])
  listingType    HomeSectionListingType @default(BOTH)
  provinceId     String?
  province       Province?              @relation(fields: [provinceId], references: [id])
  districtId     String?
  district       District?              @relation(fields: [districtId], references: [id])
  limit          Int                    @default(8)
  order          Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@map("home_sections")
}

model HomeAreaCard {
  id         String    @id @default(cuid())
  name       String
  imageKey   String
  order      Int       @default(0)
  provinceId String?
  province   Province? @relation(fields: [provinceId], references: [id])
  districtId String?
  district   District? @relation(fields: [districtId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("home_area_cards")
}
